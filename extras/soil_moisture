//stuff to use in the actual code
const int numReadings = 20; // Number of samples to average for smoothing
int readMoisture(int pin) {
  long sum = 0;
  for (int i = 0; i < numReadings; i++) {
    sum += analogRead(pin);
    delay(10); // Tiny delay between samples for stability
  }
  int averageRaw = sum / numReadings;

  // Convert raw analog (0-4095) to percentage (0-100)
  // You'll need to calibrate these numbers (AirValue vs WaterValue)
  int percentage = map(averageRaw, 3500, 1500, 0, 100); 
  return constrain(percentage, 0, 100);
}

