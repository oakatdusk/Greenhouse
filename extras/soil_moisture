//calibration code
#include <Arduino.h>

// 1. Hardware Definitions
#define SOIL_PIN 34          // Using GPIO 34 (ADC1) for stability
const int SAMPLES = 5000;      // Number of readings to average

// 2. Calibration Constants (Adjust these after your water test!)
const int DRY_VALUE = 3326;  // Value in dry air
const int WET_VALUE = 1053;  // Value in a glass of water

void setup() {
    // Start serial at high speed for ESP32
    Serial.begin(115200);
    delay(1000); 
    Serial.println("System Initialized...");
}

void loop() {
    // 3. The Smoothing Filter
    long runningTotal = 0;
    for(int i = 0; i < SAMPLES; i++) {
        runningTotal += analogRead(SOIL_PIN);
        delay(20); // Short pause between samples to let ADC settle
    }
    
    // Calculate the average of the 20 samples
    int averageRaw = runningTotal / SAMPLES;

    // 4. Percentage Logic
    // map(value, fromLow, fromHigh, toLow, toHigh)
    int humidity = map(averageRaw, WET_VALUE, DRY_VALUE, 100, 0);

    // 5. Cleanup
    // Constrain ensures the value never goes below 0% or above 100%
    int finalHumidity = constrain(humidity, 0, 100);

    // 6. Output to Serial Monitor
    Serial.print("Avg Raw: ");
    Serial.print(averageRaw);
    Serial.print(" | Moisture: ");
    Serial.print(finalHumidity);
    Serial.println("%");

    delay(1000); // Wait 1 second before next update
}


