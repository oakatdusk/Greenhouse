#include <Arduino.h>
#include <U8g2lib.h>
#include <Wire.h>

#define SDA_PIN 21
#define SCL_PIN 22

U8G2_SH1106_128X64_NONAME_F_HW_I2C u8g2(U8G2_R0, U8X8_PIN_NONE, SCL_PIN, SDA_PIN);

void setup() {
  Serial.begin(115200);
  Wire.begin(SDA_PIN, SCL_PIN, 100000); // 100 kHz I2C
  u8g2.begin();
}

void loop() {
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_ncenB08_tr);
  u8g2.drawStr(0, 10, "Hello ESP32!");
  u8g2.drawStr(0, 25, "OLED 1.3\" SH1106");
  u8g2.drawStr(0, 40, "<3");
  u8g2.sendBuffer();
  delay(1000);
}